# Sierrafy gateway configuration (see Architecture Spec v1.1 §7.2)
# Copy to .env and adjust. No secrets are committed.

# Gateway HTTP port
PORT=3000

# Seed for generating and validating API keys
API_KEY_SEED=

# Cosine similarity threshold for face match pass (face engine: MATCH_THRESHOLD)
FACE_THRESHOLD=0.82

# OCR engine: tesseract (default, offline) or google-vision (opt-in, outbound)
OCR_ENGINE=tesseract

# Required only if OCR_ENGINE=google-vision
GOOGLE_VISION_KEY=

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Privacy guarantee — must always be true. Prevents persisting biometric data.
DISABLE_BIOMETRIC_STORAGE=true

# Max requests per API key per minute
RATE_LIMIT_PER_MIN=60

# Path to the NCRA CSCA root certificate PEM for NFC passive authentication.
# Pending NCRA — see csca-certs/README.md.
NCRA_CSCA_CERT_PATH=

# If true, NFC verifications without passive auth return FAIL. Default false
# (passive auth is gated on the CSCA cert being available).
NFC_PASSIVE_AUTH_REQUIRED=false
